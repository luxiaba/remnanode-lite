# Copy this file to .env beside the Compose file and keep it mode 0600.
# Compose uses these values for interpolation and passes only the explicitly
# mapped runtime variables to the container. Shell variables override .env.

# Use an exact version or manifest digest for controlled production rollout.
# Use :latest only when automatic stable-channel tracking is intentional.
REMNANODE_IMAGE=ghcr.io/luxiaba/remnanode-lite:2.8.0

NODE_PORT=2222
SECRET_KEY=

# The small-node profile keeps the Go heap and request bodies bounded.
LOW_MEMORY=1
DISABLE_HASHED_SET_CHECK=false

# Optional overrides. Empty values use application defaults.
NODE_BIND_ADDR=
BODY_LIMIT_MB=
GOMEMLIMIT=
