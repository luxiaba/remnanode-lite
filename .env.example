# Container image tag that the v0.1.0 release workflow will publish.
# A manifest digest may replace the tag for immutable production pinning.
# Use :latest only when automatic tracking of the newest stable release is intended.
REMNANODE_IMAGE=ghcr.io/luxiaba/remnanode-lite:0.1.0

NODE_PORT=2222
SECRET_KEY=

# The 512 MiB production profile keeps the Go heap and request bodies bounded.
LOW_MEMORY=1
DISABLE_HASHED_SET_CHECK=false

# Optional overrides. Empty values use application defaults.
NODE_BIND_ADDR=
BODY_LIMIT_MB=
GOMEMLIMIT=
