# Remnanode Lite 环境配置
# 路径：/etc/remnanode/node.env
# 安装器设置为 root:remnanode 0640；请勿允许服务用户写入
#
# 借鉴官方 environment 变量名（lite-go 为裸机部署，非 Docker）：
#   NODE_PORT=2222
#   SECRET_KEY_FILE=/etc/remnanode/secret.key

# HTTPS 监听端口（Panel -> Node，须与 Panel 添加节点时一致）
NODE_PORT=2222

# 不建议内联保存 Secret Key；安装器会验证后原子写入下方受限文件
SECRET_KEY=

# Panel 下发的 base64 JSON（root:remnanode 0640）
SECRET_KEY_FILE=/etc/remnanode/secret.key

# rw-core 二进制路径
XRAY_BIN=/usr/local/lib/remnanode/rw-core

# Xray geo 资源目录
GEO_DIR=/usr/local/share/remnanode/xray

# Xray 子进程日志目录
LOG_DIR=/var/log/remnanode

# 插件 asList 共享列表使用的 ASN 前缀数据库（缺失则 asList 降级为空）
# ASN_DB_PATH=/usr/local/share/remnanode/asn/asn-prefixes.bin

# 设为 true 可禁用 hash 比对，每次 start 都强制重启 core（调试用）
DISABLE_HASHED_SET_CHECK=false

# Socket 留空使用固定默认路径；token 留空则由进程每次启动随机生成
INTERNAL_SOCKET_PATH=
INTERNAL_REST_TOKEN=

# 低内存 VPS（≤512MiB）：安装脚本会自动启用，也可显式传入 --low-memory
# LOW_MEMORY=1 时进程自动设置 180MiB Go 软内存上限（Go 有界解析 GOMEMLIMIT 后覆盖；大节点请勿误设）
# LOW_MEMORY=1
# BODY_LIMIT_MB=16
# GOMEMLIMIT=180MiB

# 可选：自定义 rw-core 下载 URL（对齐官方 Docker CUSTOM_CORE_URL）
# CUSTOM_CORE_URL=https://example.com/xray-custom

# 可选：zapret 规则文件路径（install 时复制到 GEO_DIR，供 ext:geo-zapret.dat 引用）
# GEO_ZAPRET_FILE=/path/to/geo-zapret.dat
# IP_ZAPRET_FILE=/path/to/ip-zapret.dat

# Panel 上报的 nodeVersion（默认读编译时 contract.version；仅调试或上游紧急对齐时覆盖）
# NODE_CONTRACT_VERSION=2.8.0

# systemd/OpenRC 均以 remnanode 用户运行，并授予 NET_ADMIN / NET_BIND_SERVICE ambient capabilities
