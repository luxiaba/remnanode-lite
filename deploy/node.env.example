# Remnanode Lite environment configuration
# Path: /etc/remnanode/node.env
# The installer sets ownership to root:remnanode and mode to 0640. Do not grant
# the service user write access.
#
# Environment variable names follow the official node where applicable. This
# file is for a native Remnanode Lite installation, not Docker:
#   NODE_PORT=2222
#   SECRET_KEY_FILE=/etc/remnanode/secret.key

# HTTPS listening port (Panel -> Node). It must match the port configured for
# this node in the Panel.
NODE_PORT=2222

# Storing the Secret Key inline is discouraged. The installer validates it and
# writes it atomically to the restricted file below.
SECRET_KEY=

# Base64-encoded JSON supplied by the Panel (root:remnanode, mode 0640)
SECRET_KEY_FILE=/etc/remnanode/secret.key

# Path to the rw-core binary
XRAY_BIN=/usr/local/lib/remnanode/rw-core

# Directory containing Xray geo resources
GEO_DIR=/usr/local/share/remnanode/xray

# Xray child-process log directory
LOG_DIR=/var/log/remnanode

# ASN prefix database used by the plugin asList shared list. If missing, asList
# falls back to an empty list.
# ASN_DB_PATH=/usr/local/share/remnanode/asn/asn-prefixes.bin

# Set to true to disable hash comparison and force a core restart on every
# start request. Intended for debugging only.
DISABLE_HASHED_SET_CHECK=false

# Leave the socket path empty to use the fixed default. Leave the token empty
# to generate a random token whenever the process starts.
INTERNAL_SOCKET_PATH=
INTERNAL_REST_TOKEN=

# Low-memory VPS (<=512 MiB): the installer enables this automatically, or it
# can be selected explicitly with --low-memory.
# With LOW_MEMORY=1, the process sets a 180 MiB Go soft memory limit. A valid,
# bounded GOMEMLIMIT value overrides it. Do not enable this on large nodes.
# LOW_MEMORY=1
# BODY_LIMIT_MB=16
# GOMEMLIMIT=180MiB

# Optional: custom rw-core download URL (compatible with the official Docker
# CUSTOM_CORE_URL variable)
# CUSTOM_CORE_URL=https://example.com/xray-custom

# Optional: zapret rule file paths. The installer copies these files to GEO_DIR
# so they can be referenced as ext:geo-zapret.dat and ext:ip-zapret.dat.
# GEO_ZAPRET_FILE=/path/to/geo-zapret.dat
# IP_ZAPRET_FILE=/path/to/ip-zapret.dat

# nodeVersion reported to the Panel. It defaults to the compiled contract.version;
# override it only for debugging or an urgent upstream compatibility adjustment.
# NODE_CONTRACT_VERSION=2.8.0

# Both systemd and OpenRC run as the remnanode user with the NET_ADMIN and
# NET_BIND_SERVICE ambient capabilities.
